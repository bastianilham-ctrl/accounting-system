# ============================================================
# ACCOUNTING SYSTEM - ENVIRONMENT VARIABLES
# Salin file ini menjadi .env dan isi nilai yang sesuai
# JANGAN commit file .env ke Git
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accounting_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- API Config ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=ganti_dengan_random_string_panjang_minimal_32_karakter
API_DEBUG=True

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Bank API (isi sesuai bank yang dipakai) ---
BCA_API_KEY=
BCA_API_SECRET=
BCA_CORP_ID=
OCBC_API_KEY=
OCBC_API_SECRET=

# --- Email (untuk auto-send invoice AR) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Finance System

# --- File Storage ---
UPLOAD_DIR=./uploads
OCR_TEMP_DIR=./temp/ocr

# --- Scraping ---
SCRAPE_TIMEOUT=30
SCRAPE_RETRY=3
DJP_BASE_URL=https://ereg.pajak.go.id
OSS_BASE_URL=https://oss.go.id

# --- Scheduler ---
SCHEDULER_TIMEZONE=Asia/Jakarta
DEPRECIATION_RUN_DAY=1      # tanggal berapa setiap bulan jalankan auto depresiasi
AMORTIZATION_RUN_DAY=1
